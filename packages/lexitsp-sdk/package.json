{
  "name": "@lexitsp/sdk",
  "version": "3.0.0-alpha.6",
  "description": "TypeScript SDK and CLI for Trust Standard Protocol envelopes checked with signatures, hashes, manifests, and timestamp evidence.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "import": "./dist/node/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./v3": {
      "types": "./dist/v3/index.d.ts",
      "import": "./dist/v3/index.js"
    },
    "./v3/admin": {
      "types": "./dist/v3/admin/index.d.ts",
      "import": "./dist/v3/admin/index.js"
    }
  },
  "bin": {
    "tsp": "bin/tsp.mjs"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/node/index.ts src/types.ts src/v3/index.ts src/v3/admin/index.ts src/v3/cli/index.ts --format esm --dts --out-dir dist --clean",
    "test": "vitest run"
  },
  "keywords": [
    "tsp",
    "trust-standard-protocol",
    "ai",
    "compliance",
    "eu-ai-act",
    "cryptography",
    "envelope",
    "audit-trail",
    "ai-governance"
  ],
  "homepage": "https://truststandardprotocol.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LexiTSP/sdk.git"
  },
  "author": "LexiCo AS <hello@lexico.no>",
  "dependencies": {
    "nanoid": "^5.0.9"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "vitest": "^4.1.6",
    "fast-check": "^3.19.0",
    "typescript": "5.7.2",
    "@types/node": "^22.10.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  }
}
